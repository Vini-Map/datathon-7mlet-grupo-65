# ---------------------------------------------------------------------------
# Example environment file. Copy to `.env` and fill in real values locally.
# NEVER commit a real `.env`. No secrets, no real client data — ever.
# ---------------------------------------------------------------------------

# --- LLM provider selection -------------------------------------------------
# Which LLMProvider implementation the assistant uses.
#   mock      -> deterministic offline stub (no API key needed; default for CI/demo)
#   anthropic -> Anthropic Claude API (requires ANTHROPIC_API_KEY)
AEP_LLM_PROVIDER=mock

# Anthropic API (only used when AEP_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
AEP_ANTHROPIC_MODEL=claude-opus-4-8

# --- Reproducibility --------------------------------------------------------
# Master seed for all synthetic data generation and simulations.
AEP_RANDOM_SEED=42

# --- MLflow tracking --------------------------------------------------------
# Local file-based tracking by default. Override for a remote tracking server.
MLFLOW_TRACKING_URI=file:./mlruns
AEP_MLFLOW_EXPERIMENT=aep-bandits

# --- Service ----------------------------------------------------------------
AEP_API_HOST=127.0.0.1
AEP_API_PORT=8000

# --- Data paths -------------------------------------------------------------
AEP_DATA_DIR=./data
